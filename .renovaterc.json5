{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  reviewers: [
    '@nicolerenee',
  ],
  extends: [
    'config:recommended',
    'docker:enableMajor',
    'helpers:pinGitHubActionDigests',
    'github>nicolerenee/infra//.renovate/autoMerge.json5',
    'github>nicolerenee/infra//.renovate/customManagers.json5',
    'github>nicolerenee/infra//.renovate/groups.json5',
    'github>nicolerenee/infra//.renovate/labels.json5',
    'github>nicolerenee/infra//.renovate/semanticCommits.json5',
    ':automergeBranch',
    ':disableRateLimiting',
    ':dependencyDashboard',
    ':semanticCommits',
    ':timezone(America/Chicago)',
    'github>nicolerenee/infra//.renovate/infraPackages.json5',
  ],
  rebaseWhen: 'behind-base-branch',
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  flux: {
    managerFilePatterns: [
      '/(^|/)apps/.+\\.ya?ml$/',
      '/(^|/)kubernetes/.+\\.ya?ml$/',
    ],
  },
  'helm-values': {
    managerFilePatterns: [
      '/(^|/)apps/.+\\.ya?ml$/',
      '/(^|/)kubernetes/.+\\.ya?ml$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/(^|/)apps/.+\\.ya?ml$/',
      '/(^|/)kubernetes/.+\\.ya?ml$/',
    ],
    ignorePaths: [
      'kubernetes/**/flux-system/**',
    ],
  },
  packageRules: [
    {
      // When the kubernetes-sigs/gateway-api tag in
      // scripts/vendor-gateway-api-crds.sh is bumped, re-run the vendor
      // script to regenerate the CRD YAML files in the same PR. Requires
      // RENOVATE_ALLOWED_POST_UPGRADE_COMMANDS to allowlist the script.
      matchDepNames: ['kubernetes-sigs/gateway-api'],
      postUpgradeTasks: {
        commands: ['scripts/vendor-gateway-api-crds.sh'],
        fileFilters: ['kubernetes/apps/networking/gateway-api/**'],
        executionMode: 'branch',
      },
    },
  ],
}
